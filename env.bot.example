DEEPGRAM_API_KEY=
GRADIUM_API_KEY=
CARTESIA_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
MINIMAX_API_KEY=

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=

# Trusted-backend credential sent on every edge call as X-Edge-Auth.
# Required in production. Not the BYOA wake bearer (that's per-ship).
EDGE_API_TOKEN=

# Optional: run edge-function logic in-process against Postgres instead of
# over HTTP. Set to the Supabase session pooler connection string.
LOCAL_API_POSTGRES_URL= # e.g. postgresql://postgres.{REF}:{PASS}@aws-0-{REGION}.pooler.supabase.com:5432/postgres

# Optional overrides
DAILY_API_KEY= # required for the Daily transport
TTS_PROVIDER=gradium # gradium (default) or cartesia

# Optional: Daily raw-tracks recording to a custom S3 bucket.
# Set all three to enable; requires DAILY_API_KEY above.
DAILY_RECORDING_BUCKET_NAME=
DAILY_RECORDING_BUCKET_REGION=
DAILY_RECORDING_ASSUME_ROLE_ARN=
TOKEN_USAGE_LOG= # location of token usage metrics #default:"logs/token_usage.csv"
BOT_TEST_CHARACTER_ID= # hardcode character id to join with (used in client testing)
BOT_TEST_CHARACTER_NAME= # hardcoded character name
BOT_TEST_NPC_CHARACTER_NAME= # hardcoded npc name
BOT_TEST_ACCESS_TOKEN= # dev-only: Supabase Auth access_token for local /start without going through the proxy edge function

# Event delivery: `polling` (default, HTTP against events_since) or
# `pubsub` (opt-in direct Postgres scoped pgmq reads).
EVENT_TRANSPORT=polling

# Session-mode Postgres URL with admin credentials. Required only for event pubsub.
PGMQ_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Event pubsub only: pause after an empty scoped pgmq read; non-empty reads drain immediately.
PGMQ_EMPTY_POLL_INTERVAL_SECONDS=1.0

# Event pubsub only: set to "0" to skip global chat/gm/system broadcasts.
PGMQ_SUBSCRIBE_BROADCASTS=1

# Subagent bus transport: `local` (default, in-process AsyncQueueBus) or
# `pgmq` (Postgres bus via the public.bus_* SECURITY DEFINER wrappers).
# `pgmq` is required to enable BYOA.
SUBAGENT_BUS_TRANSPORT=local
# SUBAGENT_BUS_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Optional: LLM provider configuration (defaults shown)
# Supported providers: google, anthropic, openai, minimax
VOICE_LLM_PROVIDER=openai
VOICE_LLM_MODEL=gpt-4.1-2025-04-14
TASK_LLM_PROVIDER=openai
TASK_LLM_MODEL=gpt-5.2-2025-12-11
TASK_LLM_THINKING_BUDGET=2048

# Idle task status reports (set to 0 to disable)
BOT_IDLE_REPORT_ENABLED=1
# BOT_IDLE_REPORT_TIME=7.5
# BOT_IDLE_REPORT_COOLDOWN=30

# Max task agent lifetime in seconds (cancelled on expiry). Unset = no timeout.
TASK_AGENT_TIMEOUT=1800

# UI agent LLM (optional)
UI_AGENT_LLM_PROVIDER=google
UI_AGENT_LLM_MODEL=gemini-2.5-flash
UI_AGENT_LLM_THINKING_BUDGET=0

# Ships list cache TTL for UI agent (seconds)
UI_AGENT_SHIPS_CACHE_TTL_SECS=60

# Context summarization
CONTEXT_SUMMARIZATION_MESSAGE_LIMIT=200  # messages before auto-summarization triggers

# Optional: Weave observability (W&B). Set both to enable span-based tracing
# for edge functions run locally inside the bot container.
WANDB_API_KEY=
WEAVE_PROJECT= # "entity/project" format, e.g. "my-team/gradientbang"

# Optional: Cekura tracing for simulation. Set API key and agent ID to enable.
CEKURA_API_KEY=
CEKURA_AGENT_ID=
CEKURA_TRACER_ENABLED= # set to "false" to disable without removing keys
