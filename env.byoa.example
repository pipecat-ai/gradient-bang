# env.byoa.example — template for BYOA operators
#
# Copy to `.env.byoa` and fill in. The byoa-setup Claude skill writes
# a populated version of this file from your game-account credentials;
# this template is the hand-bootstrap path.
#
# `uv run byoa` auto-loads ./.env.byoa on startup. Shell env always
# wins over file values, so you can rotate any single value with
# `BYOA_TOKEN=newtoken uv run byoa --prompt-file ./prompt.md` without
# rewriting the file.

# ── Bus transport ───────────────────────────────────────────────────
# `byoa_pgmq` routes every bus call through the token-gated
# byoa_bus_* SECURITY DEFINER wrappers so the agent's reach is
# constrained to its bound character_id, regardless of what the DSN
# could otherwise touch.
SUBAGENT_BUS_TRANSPORT=byoa_pgmq

# Postgres DSN — the transport that gets the SQL call to the database.
# Authorization lives on top via the HS256 BYOA token (see BYOA_TOKEN
# below). On managed Postgres prefer the session-mode pooler (port 5432
# on Supabase).
SUBAGENT_BUS_DATABASE_URL=

# Bus channel — MUST match the bot's value so PgmqBus peer-discovery
# finds everyone in the same deployment. Check the bot's .env / runtime
# config for the exact string.
SUBAGENT_BUS_CHANNEL=

# ── BYOA identity ───────────────────────────────────────────────────
# HS256 token bound to BYOA_CHARACTER_ID. Mint via the byoa_token_mint
# edge function (or the byoa-setup Claude skill). Rotation is
# "mint new + revoke old"; every byoa_bus_* call validates the token
# server-side, so revoked tokens fail fast.
BYOA_TOKEN=

# Operator's character — the bound subject of BYOA_TOKEN. Used in
# task_metadata.actor_character_id so server-side BYOA-private checks
# authorize against the player, not the corp ship's pseudo-character.
BYOA_CHARACTER_ID=

# Corp ship the agent acts as. Pseudo-character_id of the ship, NOT
# its UUID. The bot publishes BusTaskRequest to `byoa_<BYOA_SHIP_ID>`;
# the agent must register under that exact name.
BYOA_SHIP_ID=

# ── Optional ────────────────────────────────────────────────────────
# Path to the operator-supplied custom system prompt. `uv run byoa`
# also accepts --prompt-file; the flag wins when both are set.
# BYOA_PROMPT_FILE=./prompt.md

# Agent tunables. Defaults are safe; documented in
# docs/setup-byoa.md "Configuration".
# BYOA_HEARTBEAT_INTERVAL_SECONDS=60
# BYOA_AGENT_WAKE_TIMEOUT_SECONDS=30.0
# BYOA_AGENT_IDLE_TEARDOWN_SECONDS=300.0

# ── Bot-also-needs ──────────────────────────────────────────────────
# These are server-side knobs (set by the game operator, not the
# BYOA operator). Listed here for reference; they live in the bot's
# .env.bot and not in .env.byoa.
#   TASK_LOCK_HEARTBEAT_STALE_SECONDS=180
#   TASK_LOCK_HARD_TTL_MINUTES=30
