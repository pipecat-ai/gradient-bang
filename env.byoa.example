# env.byoa.example — template for BYOA operators
#
# Copy to `.env.byoa` and fill in. The byoa-setup Claude skill writes
# a populated version of this file from your game-account credentials;
# this template is the hand-bootstrap path.
#
# `uv run byoa` auto-loads ./.env.byoa on startup. Shell env always wins
# over file values, so you can rotate any single value with
# `BYOA_TOKEN=newtoken uv run byoa --prompt-file ./prompt.md` without
# rewriting the file.

# ── Bus + identity ──────────────────────────────────────────────────
# The BYOA process discovers its bus channel at runtime by polling
# `byoa_session_claim`. There is no client-side bus transport / channel
# env var — the server allocates a per-session channel via wake_agent
# and the claim endpoint hands it back.
#
# Postgres DSN for the pgmq connection lives in the bot's `.env.bot`
# as SUBAGENT_BUS_DATABASE_URL; `uv run byoa` loads it via the
# `.env.bot` fallback (see "LLM" section below). For standalone
# operator deploys without a bot checkout, set SUBAGENT_BUS_DATABASE_URL
# in your shell env or this file.

# byoa_session_claim edge function URL. The CLI polls this endpoint
# with `BYOA_TOKEN` to discover the channel the bot has allocated for
# your ship. Required.
# e.g. https://<project-ref>.supabase.co/functions/v1/byoa_session_claim
BYOA_CLAIM_ENDPOINT_URL=

# HS256 token bound to BYOA_CHARACTER_ID. Mint via the byoa_token_mint
# edge function (or the byoa-setup Claude skill). Rotation is
# "mint new + revoke old"; every claim/authorize call validates the
# token server-side, so revoked tokens fail fast.
BYOA_TOKEN=

# Operator's character — the bound subject of BYOA_TOKEN. Used in
# task_metadata.actor_character_id so server-side BYOA-private checks
# authorize against the player, not the corp ship's pseudo-character.
BYOA_CHARACTER_ID=

# Corp ship the agent acts as. Pseudo-character_id of the ship (NOT
# its UUID). Used as the `ship_id` body parameter on the claim call;
# the bot publishes BusTaskRequest to `byoa_<BYOA_SHIP_ID>` within
# the discovered channel.
BYOA_SHIP_ID=

# ── Optional ────────────────────────────────────────────────────────
# Path to the operator-supplied custom system prompt. `uv run byoa`
# also accepts --prompt-file; the flag wins when both are set.
# BYOA_PROMPT_FILE=./prompt.md

# Cadence (seconds) for byoa_session_claim polling between tasks.
# Default 5. Production processes spawned by wake usually claim once
# at startup; this only matters for dev / always-on operators.
# BYOA_POLL_INTERVAL_SECONDS=5

# Agent tunables. Defaults are safe; documented in
# docs/setup-byoa.md "Configuration".
# BYOA_HEARTBEAT_INTERVAL_SECONDS=60
# BYOA_AGENT_WAKE_TIMEOUT_SECONDS=30.0
# BYOA_AGENT_IDLE_TEARDOWN_SECONDS=300.0

# ── LLM ─────────────────────────────────────────────────────────────
# The BYOA task agent needs an LLM provider + key. If you're running
# BYOA from the bot's checkout, `uv run byoa` auto-loads ./.env.bot
# as a fallback (after .env.byoa + shell env), so you can leave these
# unset and inherit the bot's TASK_LLM_PROVIDER / TASK_LLM_MODEL /
# *_API_KEY. For standalone operator deploys, set them here.
# TASK_LLM_PROVIDER=openai
# TASK_LLM_MODEL=gpt-4.1
# GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── Bot-also-needs (reference only) ─────────────────────────────────
# These live on the game-operator side (bot + edge functions), not in
# .env.byoa. Listed here for cross-reference:
#   WAKE_TARGET=noop|vercel|lambda   (edge function secret)
#   TASK_LOCK_HEARTBEAT_STALE_SECONDS=180
#   TASK_LOCK_HARD_TTL_MINUTES=30
