# env.byoa.example — template for BYOA operators
#
# Copy to `.env.byoa` and fill in. The byoa-setup Claude skill writes
# a populated version of this file from your game-account credentials;
# this template is the hand-bootstrap path.
#
# `uv run byoa --serve` auto-loads ./.env.byoa on startup. Shell env always
# wins over file values, so you can rotate any single value with e.g.
# `BYOA_WAKE_SECRET=newsecret uv run byoa --serve` without rewriting the
# file.
#
# The single-session harness (`uv run byoa`, what the daemon spawns per
# wake) reads only os.environ — wake_agent injects per-session vars
# (BYOA_CHANNEL, BYOA_BUS_DATABASE_URL, BYOA_TASK_ID, …) into the spawned
# child.

# ── Identity ────────────────────────────────────────────────────────

# Operator's character — used in task_metadata.actor_character_id so
# server-side BYOA owner checks authorize against the player, not the
# corp ship's pseudo-character.
BYOA_CHARACTER_ID=

# Corp ship the agent acts as. Pseudo-character_id of the ship. The bot
# publishes BusTaskRequest to `byoa_<BYOA_SHIP_ID>` within the
# voice-session channel.
BYOA_SHIP_ID=

# Optional: HS256 token bound to BYOA_CHARACTER_ID. Currently unused at
# runtime — the bus authenticates by channel-as-capability, not by
# token. Kept here so operators can still mint a token via /byoa-setup
# for a future HTTP-side BYOA gateway.
# BYOA_TOKEN=

# Dev-only bearer for the wake handoff from `wake_agent` to a local
# `byoa --serve` daemon. MUST match BYOA_WAKE_SECRET on the bot/edge
# side. Generate a fresh random hex with e.g. `openssl rand -hex 32`.
# Do NOT reuse EDGE_API_TOKEN here — that's privileged edge-function
# auth and must not leave our infra.
BYOA_WAKE_SECRET=

# ── Prompt ──────────────────────────────────────────────────────────
# Operator-supplied custom system prompt. Up to 8 KB, appended to the
# base task-agent prompt. Set EITHER an inline string OR a file path
# (inline wins when both are set).
# BYOA_PROMPT="You are a cautious trader. ..."
# BYOA_PROMPT_FILE=./prompt.md

# ── LLM ─────────────────────────────────────────────────────────────
# The BYOA task agent needs an LLM provider + key. If you're running
# BYOA from the bot's checkout, `uv run byoa --serve` auto-loads ./.env.bot
# as a fallback (after .env.byoa + shell env), so you can leave these
# unset and inherit the bot's TASK_LLM_PROVIDER / TASK_LLM_MODEL /
# *_API_KEY. Standalone operator deploys set them here.
# TASK_LLM_PROVIDER=anthropic
# TASK_LLM_MODEL=claude-sonnet-4-5-20250929
# TASK_LLM_THINKING_BUDGET=4096
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# OPENAI_API_KEY=

# ── Tunables (optional) ─────────────────────────────────────────────
# Documented in docs/byoa.md "Configuration".
# BYOA_TOOL_CALL_TIMEOUT_SECONDS=30.0
# BYOA_AGENT_IDLE_TEARDOWN_SECONDS=300.0

# ── Bot-also-needs (reference only) ─────────────────────────────────
# These live on the game-operator side (bot + edge functions), not in
# .env.byoa. Listed here for cross-reference:
#
#   On the bot:
#     SUBAGENT_BUS_TRANSPORT=pgmq
#     SUBAGENT_BUS_DATABASE_URL=postgresql://...    # bot's privileged DSN
#     TASK_AGENT_TIMEOUT=1800                       # per-task hard upper bound
#     # Channels are server-side opaque UUIDs (`gb_<32hex>`) allocated
#     # per voice session; no SUBAGENT_BUS_CHANNEL prefix is required.
#
#   On the wake_agent edge function:
#     WAKE_TARGET=http                              # `noop` to disable wakes
#     DEFAULT_BYOA_SOURCE_URL=http://host.docker.internal:8765/wake
#     BYOA_BUS_DATABASE_URL=postgresql://byoa_login:byoa_dev_password@127.0.0.1:54322/postgres
#     BYOA_WAKE_SECRET=<same hex as above>          # same as in this file
