SUPABASE_ANON_KEY=
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=
POSTGRES_POOLER_URL=postgresql://postgres:postgres@db:5432/postgres
EDGE_API_TOKEN=

# Local dev only. When set to "1" AND EDGE_API_TOKEN is unset, edge functions
# treat untoken'd requests as admin (preserves the pre-auth-migration local
# stack flow). Never set this in production — production must always have
# EDGE_API_TOKEN configured. Presented JWTs are still verified normally.
ALLOW_AUTH_BYPASS_FOR_LOCAL_DEV=

# Optional overrides
BOT_START_URL= # used in start function to specify bot start URL. #default: "http://host.docker.internal:7860/start"
BOT_START_API_KEY= # used in start function to authenticate start request. #default: None

MOVE_DELAY_SCALE=0.25
CHARACTER_SPAWN_MP_DISTANCE=8
CHARACTER_STARTING_CREDITS=12000
CHARACTER_SKIP_AUTO_QUESTS= # set to "true" to skip auto-assigned quests (e.g. tutorial) on new character creation

# Eval webhook (Cekura integration). Only enable on eval/staging environments.
EVAL_WEBHOOK_ENABLED= # set to "true" to enable the eval_webhook edge function
CEKURA_WEBHOOK_SECRET= # shared secret for Cekura webhook authentication

# Event delivery: edge functions always dual-write into per-character pgmq
# queues alongside the events table, and broadcasts fan out via Postgres
# LISTEN/NOTIFY (notify_broadcast). No env var is needed.
# The internal HS256 signing secret used by verify_token + subscribe_my_events
# is provisioned automatically by the pgmq pubsub migration into
# public.app_runtime_config. No env var or manual ALTER step is required.

# Optional: Weave observability (W&B). Set both to enable span-based tracing.
WANDB_API_KEY=
WEAVE_PROJECT= # "entity/project" format, e.g. "my-team/gradientbang"

# Bot-process configuration (SUBAGENT_BUS_*) lives in .env.bot — see
# env.bot.example. The Supabase CLI and edge functions do not read
# those variables; sourcing them here only worked as a side effect of
# `source .env.supabase && uv run bot`, which made the bot/BYOA wire
# silently break if the recipe was skipped.
#
# Edge-function-side BYOA config:
#   WAKE_TARGET — controls wake_agent's spawn dispatch. `http` POSTs to the
#     per-ship wake URL, `noop` is a manual fallback, `vercel_sandbox` is reserved.
#   DEFAULT_BYOA_SOURCE_URL — fallback wake URL when a ship's
#     `byoa_runtime_source_url` is NULL. Optional: if unset, wake_agent uses
#     the local-dev convention `http://host.docker.internal:8765/wake` (the
#     default port for `uv run byoa --serve`). Set this in prod-style envs
#     where the daemon isn't on the docker host.
#   BYOA_BUS_DATABASE_URL — restricted Postgres DSN injected into remote BYOA
#     runners by wake_agent. This must not be the bot/service DSN. Local dev
#     uses the reset-world-provisioned restricted DSN below.
#   The wake bearer is per-ship (`byoa_wake_secret_enc`), set via
#   `ship_byoa_configure { action: 'set', wake_secret }`. There is no shared
#   env-var bearer — `EDGE_API_TOKEN` is the trusted-caller token, never sent
#   to operator runtimes.
# WAKE_TARGET=http
# DEFAULT_BYOA_SOURCE_URL=http://host.docker.internal:8765/wake
# BYOA_BUS_DATABASE_URL=postgresql://byoa_login:<password>@host/postgres
#
# Local reset-world provisions this dev-only DSN automatically:
#   postgresql://byoa_login:byoa_dev_password@127.0.0.1:54322/postgres
# reset-world reads these optional provisioning values:
# BYOA_BUS_DB_USER=byoa_login
# BYOA_BUS_DB_PASSWORD=byoa_dev_password
#
# For cloud resets, set a private BYOA_BUS_DB_PASSWORD in this env file if
# you want scripts/reset-world.sh to create/update the login password there too.
