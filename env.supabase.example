SUPABASE_ANON_KEY=
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=
POSTGRES_POOLER_URL=postgresql://postgres:postgres@db:5432/postgres
EDGE_API_TOKEN=

# Local dev only. When "1" AND EDGE_API_TOKEN is unset, edge functions
# treat untoken'd requests as admin. Never set in production.
ALLOW_AUTH_BYPASS_FOR_LOCAL_DEV=

# Optional overrides
BOT_START_URL= # used in start function to specify bot start URL. #default: "http://host.docker.internal:7860/start"
BOT_START_API_KEY= # used in start function to authenticate start request. #default: None

MOVE_DELAY_SCALE=0.25
CHARACTER_SPAWN_MP_DISTANCE=8
CHARACTER_STARTING_CREDITS=12000
CHARACTER_SKIP_AUTO_QUESTS= # set to "true" to skip auto-assigned quests (e.g. tutorial) on new character creation
CORPORATION_SHIP_OWNER_CAP=5 # active non-BYOA corporation ships a character may personally own in one corporation

# Eval webhook (Cekura integration). Only enable on eval/staging environments.
EVAL_WEBHOOK_ENABLED= # set to "true" to enable the eval_webhook edge function
CEKURA_WEBHOOK_SECRET= # shared secret for Cekura webhook authentication

# Event delivery: edge functions always write durable rows into `events`.
# Pubsub fanout targets active `event_sessions` only; offline characters do
# not receive pgmq copies. Expired session queues are dropped by the scheduled
# event-session-cleanup database job. The internal HS256 signing secret is
# auto-provisioned by migration into
# public.app_runtime_config — no env var needed.
#
# Subagent bus cleanup is also database-owned. The subagent-bus-cleanup
# pg_cron job drops orphaned q_* bus peer queues older than 48 hours.

# Optional: Weave observability (W&B). Set both to enable span-based tracing.
WANDB_API_KEY=
WEAVE_PROJECT= # "entity/project" format, e.g. "my-team/gradientbang"

# ── BYOA edge-function config ───────────────────────────────────────
# wake_agent settings. Bot-process settings (SUBAGENT_BUS_*) live in
# .env.bot, not here.
#
#   BYOA_WAKE_TARGET — `http` POSTs to the per-ship wake URL; `noop` disables
#     wakes (manual fallback); `vercel_sandbox` is reserved.
#   DEFAULT_BYOA_SOURCE_URL — optional fallback wake URL when a ship's
#     `byoa_runtime_source_url` is NULL. Leave unset to require every BYOA
#     ship to configure its own source URL.
#   BYOA_BUS_DATABASE_URL — restricted Postgres DSN injected into BYOA
#     runners by wake_agent. Must not be the bot/service DSN.
#   BYOA_WAKE_TIMEOUT_MS — abort the wake HTTP POST after this many ms.
#     Default 60000 (60s). Vercel-sandbox cold starts (first wake per ship)
#     can take 30-90s; warm resumes take 2-10s. Bump if your operators
#     consistently exceed 60s on cold start.
#
# The wake bearer is per-ship (`byoa_wake_secret_enc`), set via
# `ship_byoa_configure { action: 'set', wake_secret }`. No env-var bearer.
# BYOA_WAKE_TARGET=http
# DEFAULT_BYOA_SOURCE_URL=
# BYOA_BUS_DATABASE_URL=postgresql://byoa_login:<password>@host/postgres
# BYOA_WAKE_TIMEOUT_MS=60000
#
# reset-world.sh provisions the local dev DSN automatically:
#   postgresql://byoa_login:byoa_dev_password@127.0.0.1:54322/postgres
# Override the provisioning credentials here for cloud resets:
# BYOA_BUS_DB_USER=byoa_login
# BYOA_BUS_DB_PASSWORD=byoa_dev_password
