SUPABASE_ANON_KEY=
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=
POSTGRES_POOLER_URL=postgresql://postgres:postgres@db:5432/postgres
EDGE_API_TOKEN=

# Local dev only. When set to "1" AND EDGE_API_TOKEN is unset, edge functions
# treat untoken'd requests as admin (preserves the pre-auth-migration local
# stack flow). Never set this in production — production must always have
# EDGE_API_TOKEN configured. Presented JWTs are still verified normally.
ALLOW_AUTH_BYPASS_FOR_LOCAL_DEV=

# Optional overrides
BOT_START_URL= # used in start function to specify bot start URL. #default: "http://host.docker.internal:7860/start"
BOT_START_API_KEY= # used in start function to authenticate start request. #default: None

MOVE_DELAY_SCALE=0.25
CHARACTER_SPAWN_MP_DISTANCE=8
CHARACTER_STARTING_CREDITS=12000
CHARACTER_SKIP_AUTO_QUESTS= # set to "true" to skip auto-assigned quests (e.g. tutorial) on new character creation

# Eval webhook (Cekura integration). Only enable on eval/staging environments.
EVAL_WEBHOOK_ENABLED= # set to "true" to enable the eval_webhook edge function
CEKURA_WEBHOOK_SECRET= # shared secret for Cekura webhook authentication

# Event delivery: edge functions always dual-write into per-character pgmq
# queues alongside the events table, and broadcasts fan out via Postgres
# LISTEN/NOTIFY (notify_broadcast). No env var is needed.
# The internal HS256 signing secret used by verify_token + subscribe_my_events
# is provisioned automatically by the pgmq pubsub migration into
# public.app_runtime_config. No env var or manual ALTER step is required.

# Optional: Weave observability (W&B). Set both to enable span-based tracing.
WANDB_API_KEY=
WEAVE_PROJECT= # "entity/project" format, e.g. "my-team/gradientbang"

# Subagent bus transport (read by the bot, which sources this file in local
# dev). `local` uses the in-process AsyncQueueBus (default). `pgmq` rides the
# Postgres-backed bus an out-of-process BYOA agent connects to; DATABASE_URL
# + CHANNEL are required when transport=pgmq and the channel has no default.
SUBAGENT_BUS_TRANSPORT=local
# SUBAGENT_BUS_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# SUBAGENT_BUS_CHANNEL=  # set to a per-deployment value, e.g. gb_dev_jon

# BYOA wake mode (read by the bot). When true, the bot calls the server-side
# `wake_agent` endpoint before each BYOA-ship dispatch so a sleep-on-idle
# sandbox can cold-start in time. Leave false for always-on BYOA deploys and
# all local dev.
BYOA_WAKE_ENABLED=false
